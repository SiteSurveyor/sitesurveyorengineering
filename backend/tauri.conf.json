{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SiteSurveyor",
  "version": "0.1.0",
  "identifier": "com.succeed.sitesurveyor",
  "build": {
    "beforeDevCommand": "cd \"$INIT_CWD\" && npm run dev",
    "beforeBuildCommand": "cd \"$INIT_CWD\" && npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SiteSurveyor Engineering",
        "width": 1200,
        "height": 800,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
