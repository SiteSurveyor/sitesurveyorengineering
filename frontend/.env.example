# Public browser variables (Project Settings → API in Supabase dashboard)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Use one of these client keys (not the service_role key):
VITE_SUPABASE_ANON_KEY=your-anon-jwt-or-legacy-anon-key
# If the dashboard only shows a publishable key:
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Do not place the service role key in Vite.
